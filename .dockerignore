# Keep the build context small. Anything the builders don't need
# either bloats the upload or invalidates layer caches needlessly.
.git
.github
.idea
.vscode
*.md
docs/

# Local build outputs and binaries
nps
npc
*.exe
build/
dist/

# Frontend node_modules — the Dockerfile's node stage runs `yarn install`
# inside the container, so the host copy is irrelevant.
web-ui/node_modules/
web-ui/dist/

# Pre-built embedded SPA — regenerated by the node stage.
web/webui/dist/

# Local config / DB state — must NOT be baked into the image
conf/nps.db
conf/nps.db-shm
conf/nps.db-wal
conf/server.pem
conf/server.key
conf/clients.json
conf/hosts.json
conf/tasks.json
conf/global.json
conf/json-backup-*
conf/api_tokens.json

# Memory / scratch
/memories/
